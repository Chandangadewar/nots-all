File 1: .github/workflows/build-push.yml
yaml
# NAME of this workflow
name: Build and Push Docker Images
# WHEN should this run?
on:
  push:
    branches: [ main ]    # Run when code pushed to main branch
  pull_request:
    branches: [ main ]    # Run when PR created to main
# WHAT should it do?
jobs:
  build-and-push:           # Job name
    runs-on: ubuntu-latest  # Use GitHub's free Ubuntu server
    steps:
      # Step 1 - Download your code onto GitHub's server
      - name: Checkout code
        uses: actions/checkout@v3
      # Step 2 - Login to Docker Hub using your secrets
      - name: Login to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}  # From GitHub Secrets
          password: ${{ secrets.DOCKER_PASSWORD }}  # From GitHub Secrets
      # Step 3 - Build backend and push to Docker Hub
      - name: Build and push backend
        uses: docker/build-push-action@v5
        with:
          context: ./backend              # Use backend folder as source
          file: ./docker/backend/Dockerfile  # Use this Dockerfile
          push: true                      # Actually push to Docker Hub
          tags: chandangadewar/tastyhub-backend:latest  # Image name
      # Step 4 - Build frontend and push to Docker Hub  
      - name: Build and push frontend
        uses: docker/build-push-action@v5
        with:
          context: ./frontend             # Use frontend folder as source
          file: ./docker/frontend/Dockerfile
          push: true
          tags: chandangadewar/tastyhub-frontend:latest

File 2: .github/workflows/deploy.yml
yaml
name: Deploy to EC2
# WHEN? Only after build-push workflow succeeds
on:
  workflow_run:
    workflows: ["Build and Push Docker Images"]
    types:
      - completed
jobs:
  deploy:
    runs-on: ubuntu-latest
    # Only run if previous workflow SUCCEEDED
    if: ${{ github.event.workflow_run.conclusion == 'success' }}
    steps:
      # SSH into your EC2 server and run commands
      - name: Deploy to EC2
        uses: appleboy/ssh-action@v1.0.0
        with:
          host: ${{ secrets.EC2_HOST }}      # Your EC2 IP address
          username: ubuntu                    # EC2 username
          key: ${{ secrets.EC2_SSH_KEY }}    # Your .pem key
          script: |
            cd /home/ubuntu/tasty-hub/docker
            docker-compose pull              # Pull latest images
            docker-compose up -d             # Restart containers
            docker system prune -f           # Clean old images
